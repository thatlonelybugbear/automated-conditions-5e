<form class="ac5e-effect-value-editor-form" data-ac5e-effect-value-editor-form>
	<div class="ac5e-effect-value-editor-body">
	<fieldset class="ac5e-effect-value-editor-fieldset ac5e-effect-value-editor-primary-fieldset">
		<legend>{{headerLabel}}</legend>

		<header class="ac5e-effect-value-editor-header ac5e-effect-value-editor-inline-meta">
			<p>
				<strong>Attribute Key:</strong>
				<i
					class="fa-solid fa-circle-question ac5e-effect-value-editor-help"
					data-tooltip='For AC5E keys and examples, see <a href="https://github.com/thatlonelybugbear/automated-conditions-5e/wiki">the wiki</a>.'
					data-tooltip-direction="RIGHT"
					data-locked
				></i>
				<span>{{changeKey}}</span>
			</p>
		</header>

		{{#if hasRangeFieldToggles}}
			<div class="ac5e-effect-value-editor-toggle-grid ac5e-effect-value-editor-range-field-toggles">
				{{#each rangeFieldToggles}}
					<label title="{{hint}}">
						<input type="checkbox" name="{{name}}" {{#if checked}}checked{{/if}}>
						<span>{{label}}</span>
					</label>
				{{/each}}
			</div>
		{{/if}}

		{{#if primaryLayout}}
			<section class="ac5e-effect-value-editor-grid">
				{{#if primaryLayout.radiusField}}
					<div class="form-group">
						<label for="{{primaryLayout.radiusField.inputId}}">{{primaryLayout.radiusField.label}}</label>
						<div class="form-fields ac5e-effect-value-editor-inline-field">
							<input id="{{primaryLayout.radiusField.inputId}}" type="text" name="fields.{{primaryLayout.radiusField.name}}" value="{{primaryLayout.radiusField.value}}">
							<button
								type="button"
								class="ac5e-effect-value-editor-expand fa-solid fa-lambda fa-fw icon"
								data-ac5e-expand-input="fields.{{primaryLayout.radiusField.name}}"
								data-ac5e-expand-label="{{primaryLayout.radiusField.label}}"
								aria-label="Expand {{primaryLayout.radiusField.label}}"
							></button>
						</div>
					</div>
					<div class="form-group">
						<label for="{{primaryLayout.conditionField.inputId}}">{{primaryLayout.conditionField.label}}</label>
						<div class="form-fields ac5e-effect-value-editor-inline-field">
							<input
								id="{{primaryLayout.conditionField.inputId}}"
								type="text"
								name="conditions"
								value="{{primaryLayout.conditionField.value}}"
								placeholder="{{primaryLayout.conditionField.placeholder}}"
								data-ac5e-condition-input
							>
							<button
								type="button"
								class="ac5e-effect-value-editor-expand fa-solid fa-lambda fa-fw icon"
								data-ac5e-expand-input="conditions"
								data-ac5e-expand-label="{{primaryLayout.conditionField.label}}"
								aria-label="Expand {{primaryLayout.conditionField.label}}"
							></button>
						</div>
					</div>
				{{/if}}

				{{#each primaryLayout.mainFields}}
					<div class="form-group {{#if fullRow}}stacked ac5e-effect-value-editor-grid-span{{/if}}">
						<label for="{{inputId}}" {{#if hint}}title="{{hint}}"{{/if}}>{{label}}</label>
						<div class="form-fields ac5e-effect-value-editor-inline-field">
							{{#if hideOverrideInput}}
								<input id="{{inputId}}" type="hidden" name="fields.{{name}}" value="{{value}}">
							{{else}}
								<input id="{{inputId}}" type="text" name="fields.{{name}}" value="{{value}}">
								{{#if expandable}}
									<button
										type="button"
										class="ac5e-effect-value-editor-expand fa-solid fa-lambda fa-fw icon"
										data-ac5e-expand-input="fields.{{name}}"
										data-ac5e-expand-label="{{label}}"
										aria-label="Expand {{label}}"
									></button>
								{{/if}}
							{{/if}}
						</div>
						{{#if hasInlineOverrideEntries}}
							<div class="ac5e-effect-value-assist-chip-list ac5e-effect-value-inline-override-row">
								{{#each inlineOverrideEntries}}
									<button type="button" class="ac5e-effect-value-assist-chip{{#if selected}} active{{/if}}" data-ac5e-inline-override="{{value}}" data-ac5e-inline-override-mode="{{mode}}">{{label}}</button>
								{{/each}}
							</div>
						{{/if}}
					</div>
					{{#if companionField}}
						<div class="form-group ac5e-effect-value-editor-toggle-companion ac5e-effect-value-editor-field-companion">
							<label for="{{companionField.inputId}}">{{companionField.label}}</label>
							{{#if inlineToggle}}
								<div class="form-fields">
									<div class="form-fields ac5e-effect-value-editor-inline-field">
										<input id="{{companionField.inputId}}" type="text" name="fields.{{companionField.name}}" value="{{companionField.value}}">
										{{#if companionField.expandable}}
											<button
												type="button"
												class="ac5e-effect-value-editor-expand fa-solid fa-lambda fa-fw icon"
												data-ac5e-expand-input="fields.{{companionField.name}}"
												data-ac5e-expand-label="{{companionField.label}}"
												aria-label="Expand {{companionField.label}}"
											></button>
										{{/if}}
									</div>
									<label class="ac5e-effect-value-editor-inline-toggle">
										<input type="checkbox" name="{{inlineToggle.name}}" {{#if inlineToggle.checked}}checked{{/if}}>
										<span title="{{inlineToggle.hint}}">{{inlineToggle.label}}</span>
									</label>
								</div>
							{{else}}
								<div class="form-fields ac5e-effect-value-editor-inline-field">
									<input id="{{companionField.inputId}}" type="text" name="fields.{{companionField.name}}" value="{{companionField.value}}">
									{{#if companionField.expandable}}
										<button
											type="button"
											class="ac5e-effect-value-editor-expand fa-solid fa-lambda fa-fw icon"
											data-ac5e-expand-input="fields.{{companionField.name}}"
											data-ac5e-expand-label="{{companionField.label}}"
											aria-label="Expand {{companionField.label}}"
										></button>
									{{/if}}
								</div>
							{{/if}}
						</div>
					{{else if inlineToggle}}
						<div class="form-group ac5e-effect-value-editor-toggle-companion">
							<label>&nbsp;</label>
							<div class="form-fields">
								<label class="ac5e-effect-value-editor-inline-toggle">
									<input type="checkbox" name="{{inlineToggle.name}}" {{#if inlineToggle.checked}}checked{{/if}}>
									<span title="{{inlineToggle.hint}}">{{inlineToggle.label}}</span>
								</label>
							</div>
						</div>
					{{/if}}
				{{/each}}

				{{#unless primaryLayout.radiusField}}
				<div class="form-group ac5e-effect-value-editor-grid-span">
					<label for="{{primaryLayout.conditionField.inputId}}">{{primaryLayout.conditionField.label}}</label>
					<div class="form-fields ac5e-effect-value-editor-inline-field">
						<input
							id="{{primaryLayout.conditionField.inputId}}"
							type="text"
							name="conditions"
							value="{{primaryLayout.conditionField.value}}"
							placeholder="{{primaryLayout.conditionField.placeholder}}"
							data-ac5e-condition-input
						>
						<button
							type="button"
							class="ac5e-effect-value-editor-expand fa-solid fa-lambda fa-fw icon"
							data-ac5e-expand-input="conditions"
							data-ac5e-expand-label="{{primaryLayout.conditionField.label}}"
							aria-label="Expand {{primaryLayout.conditionField.label}}"
						></button>
					</div>
				</div>
				{{/unless}}
			</section>
		{{/if}}
	</fieldset>

	<fieldset class="ac5e-effect-value-editor-fieldset">
		<legend>Toggle Behavior</legend>
		<div class="ac5e-effect-value-editor-toggle-grid">
			{{#each toggleBehavior}}
				<label title="{{hint}}">
					<input type="checkbox" name="{{name}}" {{#if checked}}checked{{/if}}>
					<span>{{label}}</span>
				</label>
			{{/each}}
		</div>
		{{#if showCadence}}
			<div class="form-group ac5e-effect-value-editor-fieldset-select">
				<label for="ac5e-value-cadence-{{changeIndex}}">Cadence</label>
				<div class="form-fields">
					<select id="ac5e-value-cadence-{{changeIndex}}" name="ui.cadenceMode">
						{{#each cadenceOptions}}
							<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
						{{/each}}
					</select>
				</div>
			</div>
		{{/if}}
		{{#if hasOptionalFieldRows}}
			<section class="ac5e-effect-value-editor-grid">
				{{#with optionalFieldRows.nameDescription}}
					{{#if left}}
						<div class="form-group">
							<label for="{{left.inputId}}">{{left.label}}</label>
							<div class="form-fields ac5e-effect-value-editor-inline-field">
								<input id="{{left.inputId}}" type="text" name="fields.{{left.name}}" value="{{left.value}}">
								<button
									type="button"
									class="ac5e-effect-value-editor-expand fa-solid fa-lambda fa-fw icon"
									data-ac5e-expand-input="fields.{{left.name}}"
									data-ac5e-expand-label="{{left.label}}"
									aria-label="Expand {{left.label}}"
								></button>
							</div>
						</div>
					{{else}}
						<div class="ac5e-effect-value-editor-grid-placeholder"></div>
					{{/if}}
					{{#if right}}
						<div class="form-group">
							<label for="{{right.inputId}}">{{right.label}}</label>
							<div class="form-fields ac5e-effect-value-editor-inline-field">
								<input id="{{right.inputId}}" type="text" name="fields.{{right.name}}" value="{{right.value}}">
								<button
									type="button"
									class="ac5e-effect-value-editor-expand fa-solid fa-lambda fa-fw icon"
									data-ac5e-expand-input="fields.{{right.name}}"
									data-ac5e-expand-label="{{right.label}}"
									aria-label="Expand {{right.label}}"
								></button>
							</div>
						</div>
					{{else}}
						<div class="ac5e-effect-value-editor-grid-placeholder"></div>
					{{/if}}
				{{/with}}

				{{#with optionalFieldRows.usesCount}}
					{{#if left}}
						<div class="form-group">
							<label for="{{left.path.inputId}}">{{left.path.label}}</label>
							<div class="form-fields ac5e-effect-value-editor-inline-field">
								<input id="{{left.path.inputId}}" type="text" name="{{left.path.name}}" value="{{left.path.value}}">
								<button
									type="button"
									class="ac5e-effect-value-editor-expand fa-solid fa-lambda fa-fw icon"
									data-ac5e-expand-input="{{left.path.name}}"
									data-ac5e-expand-label="{{left.path.label}}"
									aria-label="Expand {{left.path.label}}"
								></button>
							</div>
						</div>
					{{else}}
						<div class="ac5e-effect-value-editor-grid-placeholder"></div>
					{{/if}}
					{{#if left}}
						<div class="form-group">
							{{#if left.amount}}
								<label for="{{left.amount.inputId}}">
									{{left.amount.label}}
									<i
										class="fa-solid fa-circle-info ac5e-effect-value-editor-label-info"
										data-tooltip="{{left.amount.hint}}"
										data-tooltip-direction="UP"
										aria-label="{{left.amount.hint}}"
									></i>
								</label>
							{{else if left.recover}}
								<label>&nbsp;</label>
							{{/if}}
							<div class="form-fields ac5e-effect-value-editor-inline-field ac5e-effect-value-editor-usescount-row">
								<div class="ac5e-effect-value-editor-usescount-primary">
									{{#if left.amount}}
										<input id="{{left.amount.inputId}}" type="text" name="{{left.amount.name}}" value="{{left.amount.value}}" placeholder="{{left.amount.placeholder}}">
									{{else if left.recover}}
										<label class="ac5e-effect-value-editor-inline-toggle ac5e-usescount-toggle-recover" title="{{left.recover.hint}}">
											<input type="checkbox" name="{{left.recover.name}}" {{#if left.recover.checked}}checked{{/if}}>
											<span>{{left.recover.label}}</span>
										</label>
									{{/if}}
								</div>
								{{#if right}}
									<div class="ac5e-effect-value-editor-usescount-options">
										{{#each right}}
											<label class="ac5e-effect-value-editor-inline-toggle {{className}}" title="{{hint}}">
												<input type="checkbox" name="{{name}}" {{#if checked}}checked{{/if}} {{#if disabled}}disabled{{/if}}>
												<span>{{label}}</span>
											</label>
										{{/each}}
									</div>
								{{/if}}
							</div>
						</div>
					{{else}}
						<div class="ac5e-effect-value-editor-grid-placeholder"></div>
					{{/if}}
					{{#if scaling}}
						<div class="form-group ac5e-effect-value-editor-grid-span">
							<div class="form-fields ac5e-effect-value-editor-scaling-grid">
								<div class="ac5e-effect-value-editor-scaling-field">
									<label for="{{scaling.min.inputId}}">{{scaling.min.label}}</label>
									<input id="{{scaling.min.inputId}}" type="text" name="{{scaling.min.name}}" value="{{scaling.min.value}}" placeholder="{{scaling.min.placeholder}}">
								</div>
								<div class="ac5e-effect-value-editor-scaling-field">
									<label for="{{scaling.max.inputId}}">{{scaling.max.label}}</label>
									<input id="{{scaling.max.inputId}}" type="text" name="{{scaling.max.name}}" value="{{scaling.max.value}}" placeholder="{{scaling.max.placeholder}}">
								</div>
								<div class="ac5e-effect-value-editor-scaling-field">
									<label for="{{scaling.step.inputId}}">{{scaling.step.label}}</label>
									<input id="{{scaling.step.inputId}}" type="text" name="{{scaling.step.name}}" value="{{scaling.step.value}}" placeholder="{{scaling.step.placeholder}}">
								</div>
							</div>
						</div>
					{{/if}}
				{{/with}}

				{{#with optionalFieldRows.update}}
					{{#if left}}
						<div class="form-group">
							<label for="{{left.path.inputId}}">{{left.path.label}}</label>
							<div class="form-fields ac5e-effect-value-editor-inline-field">
								<input id="{{left.path.inputId}}" type="text" name="{{left.path.name}}" value="{{left.path.value}}">
								<button
									type="button"
									class="ac5e-effect-value-editor-expand fa-solid fa-lambda fa-fw icon"
									data-ac5e-expand-input="{{left.path.name}}"
									data-ac5e-expand-label="{{left.path.label}}"
									aria-label="Expand {{left.path.label}}"
								></button>
							</div>
						</div>
					{{else}}
						<div class="ac5e-effect-value-editor-grid-placeholder"></div>
					{{/if}}
					{{#if left}}
						<div class="form-group">
							<label for="{{left.amount.inputId}}">
								{{left.amount.label}}
								<i
									class="fa-solid fa-circle-info ac5e-effect-value-editor-label-info"
									data-ac5e-update-amount-hint
									data-tooltip="{{left.amount.hint}}"
									data-tooltip-direction="UP"
									aria-label="{{left.amount.hint}}"
								></i>
							</label>
							<div class="form-fields ac5e-effect-value-editor-inline-field">
								<input id="{{left.amount.inputId}}" type="text" name="{{left.amount.name}}" value="{{left.amount.value}}" placeholder="{{left.amount.placeholder}}">
							</div>
						</div>
					{{else}}
						<div class="ac5e-effect-value-editor-grid-placeholder"></div>
					{{/if}}
				{{/with}}
			</section>
		{{/if}}
	</fieldset>

	{{#if hasContextBehavior}}
		<fieldset class="ac5e-effect-value-editor-fieldset">
			<legend>{{contextBehaviorLabel}}</legend>
			{{#if hasContextToggles}}
				<div class="ac5e-effect-value-editor-toggle-grid">
					{{#each contextToggles}}
						<label title="{{hint}}">
							<input type="checkbox" name="toggles.{{name}}" {{#if checked}}checked{{/if}}>
							<span>{{label}}</span>
						</label>
					{{/each}}
				</div>
			{{/if}}
		</fieldset>
	{{/if}}
	</div>

	<footer class="ac5e-effect-value-editor-footer">
		<button type="button" data-action="apply">
			<i class="fa-solid fa-check"></i>
			Apply
		</button>
		<button type="button" data-action="applyClose">
			<i class="fa-solid fa-floppy-disk"></i>
			Apply & Close
		</button>
		<button type="button" data-action="reset">
			<i class="fa-solid fa-rotate-left"></i>
			Reset
		</button>
	</footer>
</form>
